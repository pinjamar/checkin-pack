---
import Dashboard from '../../../../layouts/Dashboard.astro'
import BookingRow from '../../../../components/dashboard/BookingRow'
import RegistrationCard from '../../../../components/dashboard/RegistrationCard'
import { getSupabaseAdmin } from '../../../../lib/supabase-server'
const supabaseAdmin = getSupabaseAdmin(Astro.locals.runtime.env.SUPABASE_SERVICE_ROLE_KEY)

const user = Astro.locals.user
if (!user) return Astro.redirect('/login')

const { id } = Astro.params

// Verify ownership
const { data: apartment } = await supabaseAdmin
  .from('apartments')
  .select('*')
  .eq('id', id)
  .eq('owner_id', user.id)
  .single()

if (!apartment) return Astro.redirect('/dashboard')

// Fetch bookings
const { data: bookings } = await supabaseAdmin
  .from('bookings')
  .select('*')
  .eq('apartment_id', id)
  .order('arrival_date', { ascending: false })

// Fetch registrations for bookings with guest data (completed or already registered in eVisitor)
const completedBookingIds = (bookings || [])
  .filter((b) => b.registration_status === 'completed' || b.registration_status === 'registered')
  .map((b) => b.id)

let registrations: any[] = []
if (completedBookingIds.length > 0) {
  const { data } = await supabaseAdmin
    .from('guest_registrations')
    .select('*')
    .in('booking_id', completedBookingIds)
  registrations = data || []
}
---

<Dashboard title={`Bookings — ${apartment.name}`}>
  <a href="/dashboard" class="text-sm text-gray-500 hover:text-gray-700 mb-4 inline-block">← Back to apartments</a>
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-gray-900">{apartment.name} — Bookings</h1>
  </div>

  <!-- New booking form -->
  <div class="bg-white rounded-xl border border-gray-200 p-5 mb-6">
    <h2 class="font-semibold text-gray-800 mb-4">Add Booking</h2>
    <form id="booking-form" class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Guest name</label>
        <input type="text" id="guest_name" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-brand" />
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Guest email</label>
        <input type="email" id="guest_email" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-brand" />
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Arrival date *</label>
        <input type="date" id="arrival_date" required class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-brand" />
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Departure date *</label>
        <input type="date" id="departure_date" required class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-brand" />
      </div>
      <div class="sm:col-span-2">
        <div id="booking-error" class="hidden text-sm text-red-600 bg-red-50 p-2 rounded-lg mb-2"></div>
        <button type="submit" class="px-4 py-2 bg-brand text-white rounded-lg text-sm font-medium hover:bg-brand-dark transition-colors">
          Add Booking
        </button>
      </div>
    </form>
  </div>

  <!-- Bookings list -->
  {bookings && bookings.length > 0 ? (
    <div class="space-y-3 mb-8">
      <h2 class="font-semibold text-gray-800">All Bookings</h2>
      {bookings.map((booking) => (
        <BookingRow
          client:load
          id={booking.id}
          guest_name={booking.guest_name}
          guest_email={booking.guest_email}
          arrival_date={booking.arrival_date}
          departure_date={booking.departure_date}
          registration_status={booking.registration_status}
          pre_arrival_link_sent={booking.pre_arrival_link_sent}
        />
      ))}
    </div>
  ) : (
    <p class="text-gray-500 text-sm mb-8">No bookings yet. Add your first booking above.</p>
  )}

  <!-- Completed registrations -->
  {registrations.length > 0 && (
    <div class="space-y-4">
      <h2 class="font-semibold text-gray-800">Completed Registrations</h2>
      {registrations.map((reg) => {
        const booking = bookings?.find((b) => b.id === reg.booking_id)
        return (
          <RegistrationCard
            client:load
            bookingId={reg.booking_id}
            registrationStatus={booking?.registration_status || 'completed'}
            guest={{
              full_name: reg.full_name,
              document_type: reg.document_type,
              document_number: reg.document_number_encrypted || '',
              nationality: reg.nationality,
              date_of_birth: reg.date_of_birth,
            }}
            booking={{
              arrival_date: booking?.arrival_date || '',
              departure_date: booking?.departure_date || '',
              guest_name: booking?.guest_name || null,
            }}
          />
        )
      })}
    </div>
  )}

  <script define:vars={{ apartmentId: id }}>
    const form = document.getElementById('booking-form')
    const errorEl = document.getElementById('booking-error')

    form.addEventListener('submit', async (e) => {
      e.preventDefault()
      errorEl.classList.add('hidden')

      const body = {
        apartment_id: apartmentId,
        guest_name: document.getElementById('guest_name').value || null,
        guest_email: document.getElementById('guest_email').value || null,
        arrival_date: document.getElementById('arrival_date').value,
        departure_date: document.getElementById('departure_date').value,
      }

      const res = await fetch('/api/bookings', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      })

      if (res.ok) {
        window.location.reload()
      } else {
        const data = await res.json()
        errorEl.textContent = data.error || 'Failed to create booking'
        errorEl.classList.remove('hidden')
      }
    })
  </script>
</Dashboard>
