---
import Dashboard from '../../../../layouts/Dashboard.astro'
import GuideEditor from '../../../../components/guide-editor/GuideEditor'
import { getSupabaseAdmin } from '../../../../lib/supabase-server'
const supabaseAdmin = getSupabaseAdmin()

const user = Astro.locals.user
if (!user) return Astro.redirect('/login')

const { id } = Astro.params

// Verify ownership
const { data: apartment } = await supabaseAdmin
  .from('apartments')
  .select('*')
  .eq('id', id)
  .eq('owner_id', user.id)
  .single()

if (!apartment) return Astro.redirect('/dashboard')

// Fetch guide content
const { data: guide } = await supabaseAdmin
  .from('guide_content')
  .select('*')
  .eq('apartment_id', id)
  .single()

const guideData = guide || {
  wifi_name: null,
  wifi_password: null,
  checkin_time: null,
  checkout_time: null,
  house_rules: null,
  local_tips: [],
  emergency_contacts: [],
  custom_sections: [],
}
---

<Dashboard title={`Edit Guide — ${apartment.name}`}>
  <div class="flex items-center justify-between mb-6">
    <div>
      <a href="/dashboard" class="text-sm text-gray-500 hover:text-gray-700 mb-2 inline-block">← Back to apartments</a>
      <h1 class="text-2xl font-bold text-gray-900">{apartment.name} — Welcome Guide</h1>
      <p class="text-sm text-gray-500 mt-1">
        Edit the guide your guests will see at <a href={`/m/${apartment.slug}`} target="_blank" class="text-brand underline">/m/{apartment.slug}</a>
      </p>
    </div>
  </div>

  <GuideEditor client:load apartmentId={id!} initialData={guideData} />
</Dashboard>
