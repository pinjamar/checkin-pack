---
import Dashboard from '../../../../layouts/Dashboard.astro'
import QRDownloader from '../../../../components/qr/QRDownloader'
import { getSupabaseAdmin } from '../../../../lib/supabase-server'
const supabaseAdmin = getSupabaseAdmin(Astro.locals.runtime.env.SUPABASE_SERVICE_ROLE_KEY)

const user = Astro.locals.user
if (!user) return Astro.redirect('/login')

const { id } = Astro.params

const { data: apartment } = await supabaseAdmin
  .from('apartments')
  .select('*')
  .eq('id', id)
  .eq('owner_id', user.id)
  .single()

if (!apartment) return Astro.redirect('/dashboard')

const guideUrl = new URL(`/m/${apartment.slug}`, Astro.url.origin).href
---

<Dashboard title={`QR Code — ${apartment.name}`}>
  <a href="/dashboard" class="text-sm text-gray-500 hover:text-gray-700 mb-4 inline-block">← Back to apartments</a>
  <h1 class="text-2xl font-bold text-gray-900 mb-2">{apartment.name} — QR Code</h1>
  <p class="text-gray-500 text-sm mb-6">Print this QR code and place it in your apartment. Guests scan it to see the welcome guide.</p>

  <QRDownloader client:load url={guideUrl} apartmentName={apartment.name} />
</Dashboard>
