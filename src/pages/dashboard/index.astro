---
import Dashboard from '../../layouts/Dashboard.astro'
import ApartmentCard from '../../components/dashboard/ApartmentCard'
import UpgradePrompt from '../../components/dashboard/UpgradePrompt'
import { getSupabaseAdmin } from '../../lib/supabase-server'
const supabaseAdmin = getSupabaseAdmin(Astro.locals.runtime.env.SUPABASE_SERVICE_ROLE_KEY)

const user = Astro.locals.user
if (!user) return Astro.redirect('/login')

const { data: owner } = await supabaseAdmin.from('owners').select('plan').eq('id', user.id).single()
const plan = owner?.plan || 'free'

const today = new Date().toISOString().split('T')[0]
const startOfMonth = new Date()
startOfMonth.setDate(1)
startOfMonth.setHours(0, 0, 0, 0)

// Fetch apartments
const { data: apartments } = await supabaseAdmin
  .from('apartments')
  .select('*')
  .eq('owner_id', user.id)
  .order('created_at', { ascending: false })

const apartmentIds = (apartments || []).map((a) => a.id)

// Global stats
let activeBookings = 0, pendingRegistrations = 0, scansThisMonth = 0
let arrivalsToday: any[] = [], departuresToday: any[] = []

if (apartmentIds.length > 0) {
  const [{ count: ab }, { count: pr }, { count: scans }, { data: arrivals }, { data: departures }] = await Promise.all([
    supabaseAdmin.from('bookings').select('*', { count: 'exact', head: true }).in('apartment_id', apartmentIds).gte('departure_date', today),
    supabaseAdmin.from('bookings').select('*', { count: 'exact', head: true }).in('apartment_id', apartmentIds).eq('registration_status', 'pending'),
    supabaseAdmin.from('scan_events').select('*', { count: 'exact', head: true }).in('apartment_id', apartmentIds).gte('scanned_at', startOfMonth.toISOString()),
    supabaseAdmin.from('bookings').select('*, apartments!inner(name)').in('apartment_id', apartmentIds).eq('arrival_date', today),
    supabaseAdmin.from('bookings').select('*, apartments!inner(name)').in('apartment_id', apartmentIds).eq('departure_date', today),
  ])
  activeBookings = ab || 0
  pendingRegistrations = pr || 0
  scansThisMonth = scans || 0
  arrivalsToday = arrivals || []
  departuresToday = departures || []
}

// Per-apartment stats for cards
const apartmentStats: Record<string, { bookingsThisMonth: number; pendingRegistrations: number }> = {}
if (apartments && apartments.length > 0) {
  for (const apt of apartments) {
    const { count: bookingCount } = await supabaseAdmin
      .from('bookings').select('*', { count: 'exact', head: true }).eq('apartment_id', apt.id).gte('created_at', startOfMonth.toISOString())
    const { count: pendingCount } = await supabaseAdmin
      .from('bookings').select('*', { count: 'exact', head: true }).eq('apartment_id', apt.id).eq('registration_status', 'pending')
    apartmentStats[apt.id] = { bookingsThisMonth: bookingCount || 0, pendingRegistrations: pendingCount || 0 }
  }
}

const showUpgraded = Astro.url.searchParams.get('upgraded') === 'true'
const showLimit = Astro.url.searchParams.get('limit') === 'apartment'
const todayFormatted = new Date().toLocaleDateString('hr-HR', { weekday: 'long', day: 'numeric', month: 'long' })
---

<Dashboard title="Apartments">

  {showUpgraded && (
    <div class="mb-6 px-4 py-3 bg-green-50 border border-green-200 text-green-800 text-sm rounded-lg font-medium">
      Dobrodošli u Pro! / Welcome to Pro! — sve je otključano.
    </div>
  )}

  {showLimit && (
    <div class="mb-6 px-4 py-3 bg-amber-50 border border-amber-200 text-amber-800 text-sm rounded-lg font-medium">
      Besplatni plan dopušta 1 apartman. Nadogradite na Pro za neograničeno.
    </div>
  )}

  <!-- Stats row -->
  {apartments && apartments.length > 0 && (
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
      <div class="bg-white rounded-xl border border-gray-200 p-4">
        <div class="text-2xl font-bold text-gray-900">{activeBookings}</div>
        <div class="text-xs text-gray-500 mt-0.5">Aktivne rezervacije</div>
      </div>
      <div class="bg-white rounded-xl border border-gray-200 p-4">
        <div class="text-2xl font-bold text-gray-900">{pendingRegistrations}</div>
        <div class="text-xs text-gray-500 mt-0.5">Čeka prijava</div>
      </div>
      <div class="bg-white rounded-xl border border-gray-200 p-4">
        <div class="text-2xl font-bold text-gray-900">{apartments.length}</div>
        <div class="text-xs text-gray-500 mt-0.5">Apartmana</div>
      </div>
      <div class="bg-white rounded-xl border border-gray-200 p-4">
        <div class="text-2xl font-bold text-gray-900">{scansThisMonth}</div>
        <div class="text-xs text-gray-500 mt-0.5">QR skeniranja / mj</div>
      </div>
    </div>
  )}

  <!-- Today section -->
  {(arrivalsToday.length > 0 || departuresToday.length > 0) && (
    <div class="bg-white rounded-xl border border-gray-200 p-5 mb-6">
      <h2 class="font-semibold text-gray-800 mb-4 capitalize">{todayFormatted}</h2>
      <div class="grid md:grid-cols-2 gap-4">
        <div>
          <div class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-2">Dolasci / Arrivals ({arrivalsToday.length})</div>
          {arrivalsToday.length === 0 ? (
            <p class="text-sm text-gray-400">Nema dolazaka</p>
          ) : arrivalsToday.map((b) => (
            <div class="text-sm text-gray-700 py-1 border-b border-gray-100 last:border-0">
              <span class="font-medium">{b.guest_name || 'Gost'}</span>
              <span class="text-gray-400 ml-2">{(b as any).apartments?.name}</span>
            </div>
          ))}
        </div>
        <div>
          <div class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-2">Odlasci / Departures ({departuresToday.length})</div>
          {departuresToday.length === 0 ? (
            <p class="text-sm text-gray-400">Nema odlazaka</p>
          ) : departuresToday.map((b) => (
            <div class="text-sm text-gray-700 py-1 border-b border-gray-100 last:border-0">
              <span class="font-medium">{b.guest_name || 'Gost'}</span>
              <span class="text-gray-400 ml-2">{(b as any).apartments?.name}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  )}

  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-gray-900">Vaši apartmani</h1>
    <a
      href="/dashboard/apartment/new"
      class="px-4 py-2 bg-brand text-white rounded-lg text-sm font-medium hover:bg-brand-dark transition-colors"
    >
      + Dodaj apartman
    </a>
  </div>

  {plan === 'free' && apartments && apartments.length >= 1 && (
    <div class="mb-6">
      <UpgradePrompt client:load reason="Besplatni plan: 1 apartman, 3 rezervacije/mj. Nadogradite za neograničeno." />
    </div>
  )}

  {!apartments || apartments.length === 0 ? (
    <div class="text-center py-16 bg-white rounded-xl border border-gray-200">
      <span class="text-5xl mb-4 block">🏠</span>
      <h2 class="text-xl font-semibold text-gray-800 mb-2">Još nema apartmana</h2>
      <p class="text-gray-500 mb-6">Kreirajte prvi apartman i generirajte digitalni vodič za goste.</p>
      <a
        href="/dashboard/apartment/new"
        class="inline-block px-6 py-2.5 bg-brand text-white rounded-lg font-medium hover:bg-brand-dark transition-colors"
      >
        Kreiraj prvi apartman
      </a>
    </div>
  ) : (
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {apartments.map((apt) => (
        <ApartmentCard
          client:load
          id={apt.id}
          name={apt.name}
          slug={apt.slug}
          address={apt.address}
          cover_image_url={apt.cover_image_url}
          is_active={apt.is_active}
          bookingsThisMonth={apartmentStats[apt.id]?.bookingsThisMonth || 0}
          pendingRegistrations={apartmentStats[apt.id]?.pendingRegistrations || 0}
        />
      ))}
    </div>
  )}

</Dashboard>
