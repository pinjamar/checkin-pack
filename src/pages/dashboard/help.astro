---
import Dashboard from '../../layouts/Dashboard.astro'

const user = Astro.locals.user
if (!user) return Astro.redirect('/login')
---

<Dashboard title="Upute">
  <h1 class="text-2xl font-bold text-gray-900 mb-6 text-left">Upute</h1>

  <div class="max-w-2xl space-y-6">

    <!-- Mode A -->
    <div class="bg-white rounded-xl border border-gray-200 p-5">
      <h2 class="font-semibold text-gray-900 mb-1">Opcija A — Samo digitalni vodič</h2>
      <p class="text-sm text-gray-500 mb-4">Bez prijave gostiju, bez eVisitora. Samo vodič koji gosti mogu skenirati.</p>
      <ol class="space-y-2 text-sm text-gray-700">
        <li class="flex gap-3"><span class="shrink-0 w-5 h-5 rounded-full bg-brand text-white text-xs flex items-center justify-center font-semibold">1</span>Kreirajte apartman na dashboardu</li>
        <li class="flex gap-3"><span class="shrink-0 w-5 h-5 rounded-full bg-brand text-white text-xs flex items-center justify-center font-semibold">2</span>Kliknite <strong>Edit Guide</strong> — unesite WiFi, check-in, kućni red, savjete</li>
        <li class="flex gap-3"><span class="shrink-0 w-5 h-5 rounded-full bg-brand text-white text-xs flex items-center justify-center font-semibold">3</span>Kliknite <strong>QR</strong> — preuzmite ili ispišite QR kod i stavite ga u apartman</li>
        <li class="flex gap-3"><span class="shrink-0 w-5 h-5 rounded-full bg-brand text-white text-xs flex items-center justify-center font-semibold">4</span>Gost skenira QR → vidi vodič na mobitelu. Gotovo.</li>
      </ol>
    </div>

    <!-- Mode B -->
    <div class="bg-white rounded-xl border border-gray-200 p-5">
      <h2 class="font-semibold text-gray-900 mb-1">Opcija B — Prijava gostiju + eVisitor</h2>
      <p class="text-sm text-gray-500 mb-4">Gost sam unosi svoje podatke. Vi ih kopirate u eVisitor polje po polje.</p>
      <ol class="space-y-2 text-sm text-gray-700">
        <li class="flex gap-3"><span class="shrink-0 w-5 h-5 rounded-full bg-brand text-white text-xs flex items-center justify-center font-semibold">1</span>Kreirajte apartman i ispunite vodič (isto kao Opcija A)</li>
        <li class="flex gap-3"><span class="shrink-0 w-5 h-5 rounded-full bg-brand text-white text-xs flex items-center justify-center font-semibold">2</span>Idite na <strong>Bookings</strong> → Add Booking — unesite ime gosta, email, datum dolaska i odlaska</li>
        <li class="flex gap-3"><span class="shrink-0 w-5 h-5 rounded-full bg-brand text-white text-xs flex items-center justify-center font-semibold">3</span>Kliknite <strong>Send registration link</strong> — gost dobiva email s formom za unos podataka putovnice ili osobne</li>
        <li class="flex gap-3"><span class="shrink-0 w-5 h-5 rounded-full bg-brand text-white text-xs flex items-center justify-center font-semibold">4</span>Kad gost pošalje obrazac, status postaje <strong>Completed</strong> — u Bookings se pojavljuje kartica s podacima</li>
        <li class="flex gap-3"><span class="shrink-0 w-5 h-5 rounded-full bg-brand text-white text-xs flex items-center justify-center font-semibold">5</span>Otvorite <a href="https://www.evisitor.hr" target="_blank" class="text-brand underline">eVisitor</a> u drugoj kartici → Turisti → Prijava turista</li>
        <li class="flex gap-3"><span class="shrink-0 w-5 h-5 rounded-full bg-brand text-white text-xs flex items-center justify-center font-semibold">6</span>Na kartici kopirajte svako polje i zalijepite u eVisitor. Polja označena s <span class="text-amber-600 bg-amber-50 px-1 rounded text-xs">odaberi ručno</span> su padajući izbornici — odaberite odgovarajuću opciju ručno</li>
        <li class="flex gap-3"><span class="shrink-0 w-5 h-5 rounded-full bg-brand text-white text-xs flex items-center justify-center font-semibold">7</span>Kliknite <strong>Prijavi</strong> u eVositoru</li>
        <li class="flex gap-3"><span class="shrink-0 w-5 h-5 rounded-full bg-brand text-white text-xs flex items-center justify-center font-semibold">8</span>Vratite se u CheckinPack i kliknite <strong>Označi kao prijavljeno</strong> na kartici</li>
      </ol>
    </div>

    <!-- Edit missing data -->
    <div class="bg-white rounded-xl border border-gray-200 p-5">
      <h2 class="font-semibold text-gray-900 mb-3">Gost nije ispunio sva polja?</h2>
      <p class="text-sm text-gray-700">Kliknite <strong>Uredi</strong> na kartici s podacima i sami dopunite što nedostaje — spol, država rođenja, država i grad prebivališta. Spremite i nastavite s eVisitorom.</p>
    </div>

    <!-- Emails -->
    <div class="bg-white rounded-xl border border-gray-200 p-5">
      <h2 class="font-semibold text-gray-900 mb-3">Automatski emailovi</h2>
      <ul class="space-y-2 text-sm text-gray-700">
        <li>📧 <strong>Link za prijavu</strong> — šalje se automatski dan prije dolaska (10:00 po hrvatskom vremenu)</li>
        <li>📧 <strong>Podsjetnik za odjavu</strong> — šalje se večer prije odlaska (20:00 po hrvatskom vremenu)</li>
        <li>📧 <strong>Obavijest vlasniku</strong> — šalje se vama kada gost pošalje obrazac</li>
      </ul>
      <p class="text-xs text-gray-400 mt-3">Emailovi se šalju samo ako je booking unesen s email adresom gosta.</p>
    </div>

    <!-- Playwright autofill -->
    <div class="bg-white rounded-xl border border-gray-200 p-5">
      <h2 class="font-semibold text-gray-900 mb-3">Automatsko popunjavanje eVisitora (lokalno)</h2>
      <p class="text-sm text-gray-700 mb-3">Za vlasnike koji imaju pristup terminalu — Playwright otvara pravi browser i sam popunjava eVisitor formu iz podataka gosta.</p>
      <ol class="space-y-2 text-sm text-gray-700 mb-3">
        <li class="flex gap-3"><span class="shrink-0 w-5 h-5 rounded-full bg-brand text-white text-xs flex items-center justify-center font-semibold">1</span>Unesite ID bookinga u <code class="bg-gray-100 px-1 rounded">.dev.vars</code>: <code class="bg-gray-100 px-1 rounded">AUTOFILL_BOOKING_ID=uuid</code></li>
        <li class="flex gap-3"><span class="shrink-0 w-5 h-5 rounded-full bg-brand text-white text-xs flex items-center justify-center font-semibold">2</span>Pokrenite: <code class="bg-gray-100 px-1 rounded">npm run test:autofill</code></li>
        <li class="flex gap-3"><span class="shrink-0 w-5 h-5 rounded-full bg-brand text-white text-xs flex items-center justify-center font-semibold">3</span>Browser se otvori i popuni formu — provjerite <strong>Spol</strong> i kliknite <strong>Prijavi</strong></li>
      </ol>
      <p class="text-xs text-gray-400">Potrebni eVisitor podaci za prijavu moraju biti pohranjeni u Postavkama → eVisitor prijava.</p>
    </div>

    <!-- Cover image -->
    <div class="bg-white rounded-xl border border-gray-200 p-5">
      <h2 class="font-semibold text-gray-900 mb-3">Dodavanje naslovne fotografije</h2>
      <p class="text-sm text-gray-700">Pređite mišem preko kartice apartmana na dashboardu i kliknite na područje fotografije. Maksimalna veličina 2MB.</p>
    </div>

  </div>
</Dashboard>
