---
import Base from '../layouts/Base.astro'
---

<Base
  title="Cijene — CheckinPack"
  description="Jedan plan, sve uključeno. Počnite besplatno, nadogradite kad budete spremni."
>
  <div class="min-h-screen bg-cream py-16 px-4">
    <div class="max-w-4xl mx-auto">

      <div class="text-center mb-10">
        <h1 class="text-3xl font-bold text-gray-900 mb-2">Jedna cijena. Sve uključeno.</h1>
        <p class="text-gray-500 text-sm">One price, everything included</p>
      </div>

      <div class="grid md:grid-cols-2 gap-6 mb-8">

        <!-- Free -->
        <div class="bg-white rounded-2xl border border-gray-200 p-8 flex flex-col">
          <div class="mb-6">
            <h2 class="text-xl font-bold text-gray-900 mb-1">Besplatno <span class="text-sm font-normal text-gray-400">/ Free</span></h2>
            <div class="text-3xl font-bold text-gray-900 mt-2">€0</div>
            <p class="text-sm text-gray-400 mt-1">Za početak · To get started</p>
          </div>
          <ul class="space-y-3 mb-8 flex-1">
            <li class="flex items-start gap-2 text-sm text-gray-600">
              <span class="text-brand mt-0.5 shrink-0">✓</span>
              <span>1 apartman <span class="text-gray-400">/ 1 apartment</span></span>
            </li>
            <li class="flex items-start gap-2 text-sm text-gray-600">
              <span class="text-brand mt-0.5 shrink-0">✓</span>
              <span>3 rezervacije mjesečno <span class="text-gray-400">/ 3 bookings/month</span></span>
            </li>
            <li class="flex items-start gap-2 text-sm text-gray-600">
              <span class="text-brand mt-0.5 shrink-0">✓</span>
              <span>Digitalni vodič za goste <span class="text-gray-400">/ Digital guest guide</span></span>
            </li>
            <li class="flex items-start gap-2 text-sm text-gray-600">
              <span class="text-brand mt-0.5 shrink-0">✓</span>
              <span>QR kod <span class="text-gray-400">/ QR code</span></span>
            </li>
            <li class="flex items-start gap-2 text-sm text-gray-400">
              <span class="mt-0.5 shrink-0">✗</span>
              <span>eVisitor automatizacija</span>
            </li>
            <li class="flex items-start gap-2 text-sm text-gray-400">
              <span class="mt-0.5 shrink-0">✗</span>
              <span>AI značajke</span>
            </li>
            <li class="flex items-start gap-2 text-sm text-gray-400">
              <span class="mt-0.5 shrink-0">✗</span>
              <span>Automatski emailovi</span>
            </li>
          </ul>
          <a
            href="/signup"
            class="block w-full text-center px-4 py-3 bg-gray-100 text-gray-700 font-medium rounded-xl hover:bg-gray-200 transition-colors"
          >
            Počnite besplatno
          </a>
        </div>

        <!-- Pro -->
        <div class="bg-brand rounded-2xl p-8 text-white relative flex flex-col">
          <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-white text-brand text-xs font-bold px-3 py-1 rounded-full shadow">
            Najpopularniji
          </div>
          <div class="mb-6">
            <h2 class="text-xl font-bold mb-1">Pro</h2>
            <div class="text-3xl font-bold mt-2">€5 <span class="text-xl font-normal opacity-75">/ 3 mj.</span></div>
            <p class="text-sm opacity-75 mt-1">ili €20 / godišnje · or €20/year</p>
          </div>
          <ul class="space-y-3 mb-8 flex-1">
            <li class="flex items-start gap-2 text-sm text-white/90">
              <span class="mt-0.5 shrink-0">✓</span>
              <span>Neograničeni apartmani <span class="opacity-60">/ Unlimited apartments</span></span>
            </li>
            <li class="flex items-start gap-2 text-sm text-white/90">
              <span class="mt-0.5 shrink-0">✓</span>
              <span>Neograničene rezervacije <span class="opacity-60">/ Unlimited bookings</span></span>
            </li>
            <li class="flex items-start gap-2 text-sm text-white/90">
              <span class="mt-0.5 shrink-0">✓</span>
              <span>eVisitor podaci za kopiranje <span class="opacity-60">/ eVisitor data ready to copy</span></span>
            </li>
            <li class="flex items-start gap-2 text-sm text-white/90">
              <span class="mt-0.5 shrink-0">✓</span>
              <span>Playwright auto-fill</span>
            </li>
            <li class="flex items-start gap-2 text-sm text-white/90">
              <span class="mt-0.5 shrink-0">✓</span>
              <span>Automatski emailovi i podsjetnici <span class="opacity-60">/ Automated emails & reminders</span></span>
            </li>
            <li class="flex items-start gap-2 text-sm text-white/90">
              <span class="mt-0.5 shrink-0">✓</span>
              <span>Sinkronizacija s Booking.com/Airbnb <span class="opacity-60">/ Calendar sync</span></span>
            </li>
            <li class="flex items-start gap-2 text-sm text-white/90">
              <span class="mt-0.5 shrink-0">✓</span>
              <span>AI generator dobrodošlice i kućnog reda <span class="opacity-60">/ AI welcome & house rules</span></span>
            </li>
          </ul>
          <div class="space-y-3">
            <button
              id="btn-3month"
              class="block w-full text-center px-4 py-3 bg-white text-brand font-semibold rounded-xl hover:bg-white/90 transition-colors"
            >
              Probajte 3 mjeseca za €5
            </button>
            <button
              id="btn-annual"
              class="block w-full text-center px-4 py-3 bg-white/20 text-white font-medium rounded-xl hover:bg-white/30 transition-colors"
            >
              ili €20 / godišnje
            </button>
          </div>
        </div>

      </div>

      <p class="text-center text-xs text-gray-400 mb-12">Bez skrivenih troškova · No hidden fees</p>

      <!-- FAQ -->
      <div class="max-w-2xl mx-auto space-y-4">
        <h2 class="font-semibold text-gray-900 mb-4 text-lg">Česta pitanja</h2>

        <details class="group bg-white rounded-2xl border border-gray-200">
          <summary class="flex items-center justify-between p-5 cursor-pointer font-medium text-gray-900 list-none">
            Mogu li promijeniti plan kasnije?
            <span class="text-gray-400 group-open:rotate-180 transition-transform">↓</span>
          </summary>
          <div class="px-5 pb-5 text-sm text-gray-600">
            Da, u bilo koje vrijeme iz postavki. Možete nadograditi na godišnji plan ili otkazati — bez ugovora.
          </div>
        </details>

        <details class="group bg-white rounded-2xl border border-gray-200">
          <summary class="flex items-center justify-between p-5 cursor-pointer font-medium text-gray-900 list-none">
            Što se događa ako otkažem?
            <span class="text-gray-400 group-open:rotate-180 transition-transform">↓</span>
          </summary>
          <div class="px-5 pb-5 text-sm text-gray-600">
            Vraćate se na besplatni plan — svi vaši podaci i apartmani ostaju. Ništa se ne briše.
          </div>
        </details>

        <details class="group bg-white rounded-2xl border border-gray-200">
          <summary class="flex items-center justify-between p-5 cursor-pointer font-medium text-gray-900 list-none">
            Prihvaćate li kartice iz Hrvatske?
            <span class="text-gray-400 group-open:rotate-180 transition-transform">↓</span>
          </summary>
          <div class="px-5 pb-5 text-sm text-gray-600">
            Da — sve glavne kartice putem Stripe-a (Visa, Mastercard, Amex). Plaćanje je sigurno i kriptirano.
          </div>
        </details>

        <details class="group bg-white rounded-2xl border border-gray-200">
          <summary class="flex items-center justify-between p-5 cursor-pointer font-medium text-gray-900 list-none">
            Jesu li podaci gostiju sigurni?
            <span class="text-gray-400 group-open:rotate-180 transition-transform">↓</span>
          </summary>
          <div class="px-5 pb-5 text-sm text-gray-600">
            Da. Podaci putovnice su kriptirani i automatski se brišu 30 dana nakon odjave gosta. Pohranjujemo ih u EU (Supabase EU region).
          </div>
        </details>
      </div>

    </div>
  </div>
</Base>

<script>
  async function checkout(interval: 'annual' | '3month') {
    const btn = document.getElementById(interval === 'annual' ? 'btn-annual' : 'btn-3month') as HTMLButtonElement
    const original = btn.textContent
    btn.textContent = '...'
    btn.disabled = true
    try {
      const res = await fetch('/api/stripe/create-checkout', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ interval }),
      })
      const data = await res.json()
      if (data.url) window.location.href = data.url
      else {
        btn.textContent = original
        btn.disabled = false
      }
    } catch {
      btn.textContent = original
      btn.disabled = false
    }
  }

  document.getElementById('btn-annual')?.addEventListener('click', () => checkout('annual'))
  document.getElementById('btn-3month')?.addEventListener('click', () => checkout('3month'))
</script>
