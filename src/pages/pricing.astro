---
import Base from '../layouts/Base.astro'
import { PLANS } from '../lib/stripe'
---

<Base title="Cijene — CheckinPack">
  <div class="min-h-screen bg-gray-50 py-16 px-4">
    <div class="max-w-4xl mx-auto">

      <div class="text-center mb-12">
        <h1 class="text-3xl font-bold text-gray-900 mb-3">Jedna cijena. Sve uključeno.</h1>
        <p class="text-gray-500 text-lg">Plaćate jednom godišnje, pokriveni ste cijelu sezonu.</p>
      </div>

      <div class="grid md:grid-cols-2 gap-6 mb-12">

        <!-- Free -->
        <div class="bg-white rounded-2xl border border-gray-200 p-8">
          <div class="mb-6">
            <h2 class="text-xl font-bold text-gray-900 mb-1">Besplatno</h2>
            <div class="text-3xl font-bold text-gray-900">€0</div>
            <p class="text-sm text-gray-500 mt-1">Za testiranje</p>
          </div>
          <ul class="space-y-3 mb-8">
            {PLANS.free.features.map((f) => (
              <li class="flex items-start gap-2 text-sm text-gray-600">
                <span class="text-gray-400 mt-0.5">✓</span>
                <span>{f}</span>
              </li>
            ))}
          </ul>
          <a
            href="/signup"
            class="block w-full text-center px-4 py-3 bg-gray-100 text-gray-700 font-medium rounded-lg hover:bg-gray-200 transition-colors"
          >
            Počnite besplatno
          </a>
        </div>

        <!-- Pro (highlighted) -->
        <div class="bg-brand rounded-2xl p-8 text-white relative">
          <div class="absolute top-4 right-4 bg-white/20 text-white text-xs font-medium px-2.5 py-1 rounded-full">
            Preporučeno
          </div>
          <div class="mb-6">
            <h2 class="text-xl font-bold mb-1">Pro</h2>
            <div class="text-3xl font-bold">€20 <span class="text-xl font-normal opacity-75">/ godišnje</span></div>
            <p class="text-sm opacity-75 mt-1">ili €5 / 3 mj — bez obaveze</p>
          </div>
          <ul class="space-y-3 mb-8">
            {PLANS.pro.features.map((f) => (
              <li class="flex items-start gap-2 text-sm text-white/90">
                <span class="mt-0.5">✓</span>
                <span>{f}</span>
              </li>
            ))}
          </ul>
          <div class="space-y-3">
            <button
              id="btn-annual"
              class="block w-full text-center px-4 py-3 bg-white text-brand font-semibold rounded-lg hover:bg-white/90 transition-colors"
            >
              €20/godišnje — plati prije sezone
            </button>
            <button
              id="btn-3month"
              class="block w-full text-center px-4 py-3 bg-white/20 text-white font-medium rounded-lg hover:bg-white/30 transition-colors"
            >
              ili €5 / 3 mj
            </button>
          </div>
        </div>

      </div>

      <!-- FAQ -->
      <div class="bg-white rounded-2xl border border-gray-200 p-8 max-w-2xl mx-auto">
        <h2 class="font-semibold text-gray-900 mb-6">Često postavljana pitanja</h2>
        <dl class="space-y-5">
          <div>
            <dt class="font-medium text-gray-800 mb-1">Mogu li otkazati?</dt>
            <dd class="text-sm text-gray-600">Da, u bilo koje vrijeme. Upravljate pretplatom sami iz postavki — nema skrivenih ugovora.</dd>
          </div>
          <div>
            <dt class="font-medium text-gray-800 mb-1">Je li sigurno čuvanje podataka gostiju?</dt>
            <dd class="text-sm text-gray-600">Da. Podaci putovnice su kriptirani, a automatski se brišu 30 dana nakon odjave.</dd>
          </div>
          <div>
            <dt class="font-medium text-gray-800 mb-1">Trebam li kreditnu karticu za besplatni plan?</dt>
            <dd class="text-sm text-gray-600">Ne. Besplatni plan ne zahtijeva nikakve podatke o plaćanju.</dd>
          </div>
          <div>
            <dt class="font-medium text-gray-800 mb-1">Can I cancel? / Is it safe?</dt>
            <dd class="text-sm text-gray-600">Yes, cancel anytime. Guest passport data is encrypted and auto-deleted 30 days after checkout. No credit card needed for the free plan.</dd>
          </div>
        </dl>
      </div>

    </div>
  </div>
</Base>

<script>
  async function checkout(interval: 'annual' | '3month') {
    const btn = document.getElementById(interval === 'annual' ? 'btn-annual' : 'btn-3month') as HTMLButtonElement
    btn.textContent = '...'
    btn.disabled = true
    try {
      const res = await fetch('/api/stripe/create-checkout', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ interval }),
      })
      const data = await res.json()
      if (data.url) window.location.href = data.url
      else {
        btn.textContent = interval === 'annual' ? '€20/godišnje — plati prije sezone' : 'ili €5 / 3 mj'
        btn.disabled = false
      }
    } catch {
      btn.disabled = false
    }
  }

  document.getElementById('btn-annual')?.addEventListener('click', () => checkout('annual'))
  document.getElementById('btn-3month')?.addEventListener('click', () => checkout('3month'))
</script>
