---
import '../styles/global.css'

interface Props {
  title: string
}

const { title } = Astro.props

const currentPath = Astro.url.pathname
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <title>{title} | CheckinPack.hr</title>
    <style>
      body { font-family: 'Inter', sans-serif; }
    </style>
  </head>
  <body class="bg-gray-50 min-h-screen">
    <div class="flex min-h-screen">
      <!-- Sidebar -->
      <aside class="hidden md:flex w-64 bg-white border-r border-gray-200 flex-col">
        <div class="p-6 border-b border-gray-200">
          <a href="/dashboard" class="text-xl font-bold text-brand">CheckinPack</a>
        </div>
        <nav class="flex-1 p-4 space-y-1">
          <a
            href="/dashboard"
            class:list={[
              'block px-4 py-2.5 rounded-lg text-sm font-medium transition-colors',
              currentPath === '/dashboard' || currentPath === '/dashboard/'
                ? 'bg-brand-light text-brand'
                : 'text-gray-600 hover:bg-gray-100'
            ]}
          >
            Apartments
          </a>
          <a
            href="/dashboard/settings"
            class:list={[
              'block px-4 py-2.5 rounded-lg text-sm font-medium transition-colors',
              currentPath.startsWith('/dashboard/settings')
                ? 'bg-brand-light text-brand'
                : 'text-gray-600 hover:bg-gray-100'
            ]}
          >
            Settings
          </a>
        </nav>
        <div class="p-4 border-t border-gray-200">
          <button id="logout-btn" class="w-full px-4 py-2 text-sm text-gray-600 hover:text-gray-900 text-left">
            Log out
          </button>
        </div>
      </aside>

      <!-- Mobile header -->
      <div class="flex-1 flex flex-col">
        <header class="md:hidden flex items-center justify-between p-4 bg-white border-b border-gray-200">
          <a href="/dashboard" class="text-lg font-bold text-brand">CheckinPack</a>
          <div class="flex gap-3">
            <a href="/dashboard" class="text-sm text-gray-600">Home</a>
            <a href="/dashboard/settings" class="text-sm text-gray-600">Settings</a>
          </div>
        </header>

        <!-- Main content -->
        <main class="flex-1 p-4 md:p-8 max-w-6xl">
          <slot />
        </main>
      </div>
    </div>

    <script>
      import { supabase } from '../lib/supabase'
      document.getElementById('logout-btn')?.addEventListener('click', async () => {
        await supabase.auth.signOut()
        window.location.href = '/login'
      })
    </script>
  </body>
</html>
