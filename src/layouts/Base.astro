---
import '../styles/global.css'

interface Props {
  title: string
  description?: string
}

const { title, description = 'CheckinPack.hr - Digital welcome guides for Croatian apartments' } = Astro.props
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <title>{title} | CheckinPack.hr</title>
    <style>
      body { font-family: 'Inter', sans-serif; }
    </style>
  </head>
  <body class="bg-cream text-gray-900 min-h-screen">
    <nav class="sticky top-0 z-50 bg-cream/90 backdrop-blur border-b border-gray-200">
      <div class="max-w-5xl mx-auto px-4 h-14 flex items-center justify-between">
        <a href="/" class="font-bold text-brand text-lg tracking-tight">CheckinPack.hr</a>
        <div class="flex items-center gap-3">
          <a href="/pricing" class="text-sm text-gray-600 hover:text-gray-900 hidden sm:block">Cijene</a>
          <a href="/login" class="text-sm text-gray-600 hover:text-gray-900 hidden sm:block">Prijava</a>
          <a href="/signup" class="text-sm px-4 py-2 bg-brand text-white rounded-lg font-medium hover:bg-brand-dark transition-colors">
            Počnite besplatno
          </a>
        </div>
      </div>
    </nav>
    <slot />
  </body>
</html>
